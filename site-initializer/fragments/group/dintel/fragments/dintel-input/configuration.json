{
  "fieldSets": [
    {
      "fields": [
        {
          "dataType": "string",
          "defaultValue": "text",
          "label": "Tipo",
          "name": "type",
          "type": "select",
          "typeOptions": {
            "validValues": [
              {"value": "text",     "label": "Texto"},
              {"value": "email",    "label": "Email"},
              {"value": "password", "label": "Contraseña"},
              {"value": "tel",      "label": "Teléfono"},
              {"value": "url",      "label": "URL"}
            ]
          }
        },
        {
          "dataType": "string",
          "defaultValue": "md",
          "label": "Tamaño",
          "name": "size",
          "type": "select",
          "typeOptions": {
            "validValues": [
              {"value": "sm", "label": "Small"},
              {"value": "md", "label": "Medium"},
              {"value": "lg", "label": "Large"}
            ]
          }
        },
        {
          "dataType": "string",
          "defaultValue": "default",
          "label": "Estado",
          "name": "state",
          "type": "select",
          "typeOptions": {
            "validValues": [
              {"value": "default", "label": "Default"},
              {"value": "success", "label": "Éxito"},
              {"value": "error",   "label": "Error"},
              {"value": "warning", "label": "Advertencia"}
            ]
          }
        },
        {"defaultValue": "true",  "label": "Mostrar etiqueta",      "name": "showLabel",    "type": "checkbox"},
        {"defaultValue": "false", "label": "Mostrar texto de ayuda", "name": "showHelp",     "type": "checkbox"},
        {"defaultValue": "false", "label": "Campo obligatorio",      "name": "required",     "type": "checkbox"},
        {"defaultValue": "false", "label": "Deshabilitado",          "name": "disabled",     "type": "checkbox"},
        {"defaultValue": "false", "label": "Ancho completo",          "name": "fullWidth",    "type": "checkbox"}
      ],
      "label": "Campo de texto"
    }
  ]
}
